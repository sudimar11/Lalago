rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Temporary rules for testing
    // WARNING: These rules are NOT for production use
    // Validate riderAvailability values on user documents
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null
        && (!('riderAvailability' in request.resource.data) ||
            request.resource.data.riderAvailability in
            ['available', 'on_delivery', 'on_break', 'offline',
             'checked_out', 'suspended']);
    }

    match /{document=**} {
      // Reads remain open for now; writes require authentication.
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: require authenticated user and strict author binding
    match /orders/{orderId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.authorID is string
        && request.resource.data.authorID == request.auth.uid;

      // Prevent changing authorID, and only allow the author to update
      allow update: if request.auth != null
        && resource.data.authorID is string
        && resource.data.authorID == request.auth.uid
        && request.resource.data.authorID == resource.data.authorID;

      allow delete: if false;
    }
    
    // Specific rules for daily notes and reactions
    match /daily_summaries/{date}/notes/{noteId} {
      allow read, write: if request.auth != null;
      
      // Allow reactions on notes
      match /reactions/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Driver collection records - immutable audit trail
    // Records can only be created, never updated or deleted
    match /driver_collections/{collectionId} {
      // Allow read for authenticated users
      allow read: if request.auth != null;
      
      // Allow create only with required fields and immutable flag
      // Ensure all required fields are present and immutable flag is set
      allow create: if request.auth != null
        && request.resource.data.immutable == true
        && request.resource.data.collectionId is string
        && request.resource.data.driverId is string
        && request.resource.data.driverName is string
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.walletBalanceBefore is number
        && request.resource.data.walletBalanceAfter is number
        && request.resource.data.createdAt is timestamp
        && request.resource.data.status is string
        && request.resource.data.collectionType is string;
      
      // Prevent updates - records are immutable
      allow update: if false;
      
      // Prevent deletes - records are immutable
      allow delete: if false;
    }
    
    // Broadcast notification jobs: Admin app creates docs and listens for
    // progress; Cloud Function (Admin SDK) updates them. Allow auth users.
    match /notification_jobs/{jobId} {
      allow create, read: if request.auth != null;
      allow update, delete: if false;
    }

    // Bundle Deals: read for all (Customer/Rider), write for authenticated (Admin)
    match /bundles/{bundleId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Bundle analytics: read for authenticated (reporting), write only via Cloud Functions
    match /bundle_analytics/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // Add-on Promos: read for all (Customer/Rider), write for authenticated (Admin)
    match /addon_promos/{promoId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Add-on promo analytics: write only via Cloud Functions
    match /addon_promo_analytics/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // Dispatch settings: admin read/write for auto-dispatch toggle
    match /config/dispatch_settings {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Restaurant order settings (device status, SMS contact, timeout)
    match /vendors/{vendorId}/settings/{docId} {
      allow read, write: if request.auth != null;
    }

    // Ash scheduled notifications: user can read/create/update/delete own docs
    match /ash_scheduled_notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Ash notification history: user can read own; create via Cloud Functions only
    match /ash_notification_history/{historyId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // User carts: user can read/write own cart for cart recovery sync
    match /user_carts/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Cart recovery analytics: read for admin, write via Cloud Functions only
    match /cart_recovery_analytics/{doc} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // Order failures: admin/Cloud Functions only (write by Cloud Functions)
    match /order_failures/{failure} {
      allow read, write: if false;
    }

    // Retry attempts: admin/Cloud Functions only
    match /retry_attempts/{attempt} {
      allow read, write: if false;
    }

    // Trending products: read for all, write via Cloud Functions only
    match /trending_products/{product} {
      allow read: if true;
      allow write: if false;
    }

    // Recommendation feedback: authenticated users create own feedback
    match /recommendation_feedback/{feedback} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // A/B tests: read for authenticated, write admin only
    match /ab_tests/{test} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // A/B assignments: user can read own, write via Cloud Functions only
    match /ab_assignments/{assignment} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Notification action stats: read for admin, write via Cloud Functions only
    match /action_stats/{stat} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Notification action analytics: read for admin, write via Cloud Functions only
    match /action_analytics/{analytic} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Ash voice metrics: read for admin, write via Cloud Functions only
    match /ash_voice_metrics/{metric} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Ash voice analysis: read for admin, write via Cloud Functions only
    match /ash_voice_analysis/{analysis} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Audit logs: read for authenticated (admin), create/write via Cloud Functions only
    match /audit_logs/{logId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // Analytics aggregates: read for authenticated, write via Cloud Functions only
    match /notification_aggregates/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /user_daily_metrics/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /revenue_daily_metrics/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /ltv_aggregates/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /ab_test_results/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Analytics events: create for authenticated, read for authenticated
    match /notification_actions/{doc} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }
    match /conversion_events/{doc} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }
    match /user_engagement/{doc} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }
    match /funnel_steps/{doc} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }

    // Weekly reports: read for authenticated (admin)
    match /weekly_reports/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // TODO: Replace with proper security rules before production deployment
    // Example of proper rules:
    // match /users/{userId} {
    //   allow read, write: if request.auth != null && request.auth.uid == userId;
    // }
    // 
    // match /sms_campaigns/{campaignId} {
    //   allow read, write: if request.auth != null;
    // }
    // 
    // match /sms_results/{resultId} {
    //   allow read, write: if request.auth != null;
    // }
    // 
    // match /sms_logs/{logId} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
