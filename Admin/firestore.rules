rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Temporary rules for testing
    // WARNING: These rules are NOT for production use
    // Validate riderAvailability values on user documents
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null
        && (!('riderAvailability' in request.resource.data) ||
            request.resource.data.riderAvailability in
            ['available', 'on_delivery', 'on_break', 'offline',
             'checked_out', 'suspended']);
    }

    match /{document=**} {
      // Reads remain open for now; writes require authentication.
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: require authenticated user and strict author binding
    match /orders/{orderId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.authorID is string
        && request.resource.data.authorID == request.auth.uid;

      // Prevent changing authorID, and only allow the author to update
      allow update: if request.auth != null
        && resource.data.authorID is string
        && resource.data.authorID == request.auth.uid
        && request.resource.data.authorID == resource.data.authorID;

      allow delete: if false;
    }
    
    // Specific rules for daily notes and reactions
    match /daily_summaries/{date}/notes/{noteId} {
      allow read, write: if request.auth != null;
      
      // Allow reactions on notes
      match /reactions/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Driver collection records - immutable audit trail
    // Records can only be created, never updated or deleted
    match /driver_collections/{collectionId} {
      // Allow read for authenticated users
      allow read: if request.auth != null;
      
      // Allow create only with required fields and immutable flag
      // Ensure all required fields are present and immutable flag is set
      allow create: if request.auth != null
        && request.resource.data.immutable == true
        && request.resource.data.collectionId is string
        && request.resource.data.driverId is string
        && request.resource.data.driverName is string
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.walletBalanceBefore is number
        && request.resource.data.walletBalanceAfter is number
        && request.resource.data.createdAt is timestamp
        && request.resource.data.status is string
        && request.resource.data.collectionType is string;
      
      // Prevent updates - records are immutable
      allow update: if false;
      
      // Prevent deletes - records are immutable
      allow delete: if false;
    }
    
    // Broadcast notification jobs: Admin app creates docs and listens for
    // progress; Cloud Function (Admin SDK) updates them. Allow auth users.
    match /notification_jobs/{jobId} {
      allow create, read: if request.auth != null;
      allow update, delete: if false;
    }

    // Bundle Deals: read for all (Customer/Rider), write for authenticated (Admin)
    match /bundles/{bundleId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Bundle analytics: read for authenticated (reporting), write only via Cloud Functions
    match /bundle_analytics/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // Add-on Promos: read for all (Customer/Rider), write for authenticated (Admin)
    match /addon_promos/{promoId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Add-on promo analytics: write only via Cloud Functions
    match /addon_promo_analytics/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // TODO: Replace with proper security rules before production deployment
    // Example of proper rules:
    // match /users/{userId} {
    //   allow read, write: if request.auth != null && request.auth.uid == userId;
    // }
    // 
    // match /sms_campaigns/{campaignId} {
    //   allow read, write: if request.auth != null;
    // }
    // 
    // match /sms_results/{resultId} {
    //   allow read, write: if request.auth != null;
    // }
    // 
    // match /sms_logs/{logId} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
