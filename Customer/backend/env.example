# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_PROJECT_NUMBER=your-project-number
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
# Option 1: Use service account key file path
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option 2: Use service account key as JSON string (for cloud deployment)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Expected App Configuration
EXPECTED_PACKAGE_NAME=com.foodies.lalago.android
EXPECTED_APP_CERTIFICATE_SHA256=your-app-certificate-sha256

# Server Configuration
PORT=3000
NODE_ENV=production

# API Security
API_KEY=your-secure-api-key
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
